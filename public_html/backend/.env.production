# Backend Production Configuration
# Copy this to /opt/ekam-backend/.env on the VPS

BACKEND_PORT=8001
BACKEND_HOST=0.0.0.0
WORKERS=4

# Database path (SQLite)
DATABASE_PATH=/opt/ekam-backend/data/ekam.db

# File storage
UPLOAD_DIR=/opt/ekam-backend/data/uploads
AUDIO_DIR=/opt/ekam-backend/data/audio

# Limits
MAX_FILE_SIZE_MB=128
MAX_TEXT_LENGTH=50000

# Logging
LOG_LEVEL=info
