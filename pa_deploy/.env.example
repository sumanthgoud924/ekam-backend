# Ekam Multi-Purpose App - Backend Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# Server Configuration
# ===========================================
PORT=8001
PYTHONUNBUFFERED=1

# ===========================================
# Database Configuration
# ===========================================
DATABASE_PATH=./data/ekam.db

# ===========================================
# File Storage Paths
# ===========================================
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
AUDIO_DIR=./data/audio
MODELS_DIR=./models/weights

# ===========================================
# Upload Limits
# ===========================================
MAX_FILE_SIZE_MB=50
MAX_TEXT_LENGTH=50000

# ===========================================
# CORS Configuration (comma-separated)
# ===========================================
CORS_ORIGINS=https://ekam.digital,https://www.ekam.digital,http://localhost:3000,http://localhost:5173

# ===========================================
# AI/LLM API Keys (Optional - uses NVIDIA NIM by default)
# ===========================================
# NVIDIA NIM API keys are embedded in ai_client.py
# Add your own keys here if using different providers:
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
# GOOGLE_API_KEY=your_google_key

# ===========================================
# TTS/STT Configuration
# ===========================================
DEFAULT_TTS_PROVIDER=edge_tts
DEFAULT_STT_PROVIDER=whisper
DEFAULT_TTS_LANGUAGE=en
DEFAULT_STT_LANGUAGE=en

# ===========================================
# Production Settings (set in deployment platform)
# ===========================================
# RENDER=true (or RAILWAY_ENVIRONMENT=production, FLY_APP_NAME=ekam-backend)
# DATABASE_URL=postgresql://... (if using PostgreSQL instead of SQLite)